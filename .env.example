# OpenEOS Shop - Environment Configuration
#
# Copy to `.env.local` for local dev. In production, NEXT_PUBLIC_* values are
# baked into the client bundle at `next build` time (see Dockerfile ARGs and
# the GitHub Actions workflow). Real values must NOT be committed.

# Base URL of the OpenEOS API (consumed by src/lib/api.ts)
NEXT_PUBLIC_API_URL=http://localhost:3010/api
